# =============================================================================
# EMAIL CAMPAIGN SYSTEM - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and update with your actual values
# DO NOT commit .env to version control
# =============================================================================

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME="Email Campaign System"
APP_ENV=development
APP_DEBUG=true
APP_VERSION=1.0.0
APP_TIMEZONE=UTC

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=120s
SERVER_SHUTDOWN_TIMEOUT=30s

# API Configuration
API_PREFIX=/api/v1
API_RATE_LIMIT=100
API_RATE_LIMIT_WINDOW=1m

# =============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# =============================================================================
DATABASE_DRIVER=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=email_campaign
DATABASE_USER=postgres
DATABASE_PASSWORD=your_secure_password
DATABASE_SSLMODE=disable
DATABASE_TIMEZONE=UTC

# Connection Pool
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=10
DATABASE_CONN_MAX_LIFETIME=5m
DATABASE_CONN_MAX_IDLE_TIME=10m

# Migration
DATABASE_MIGRATION_PATH=./migrations
DATABASE_AUTO_MIGRATE=false

# Full connection string (alternative to individual params)
# DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=disable

# =============================================================================
# CACHE CONFIGURATION (Redis)
# =============================================================================
CACHE_DRIVER=redis
CACHE_TTL=3600

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=5
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s
REDIS_POOL_TIMEOUT=4s
REDIS_IDLE_TIMEOUT=5m

# Redis Cluster (if using cluster mode)
REDIS_CLUSTER_ENABLED=false
REDIS_CLUSTER_ADDRS=localhost:7000,localhost:7001,localhost:7002

# Full Redis URL (alternative)
# REDIS_URL=redis://user:password@localhost:6379/0

# =============================================================================
# FILE STORAGE
# =============================================================================
STORAGE_DRIVER=local
STORAGE_PATH=./storage

# Templates
TEMPLATE_STORAGE_PATH=./storage/templates
TEMPLATE_CACHE_ENABLED=true
TEMPLATE_CACHE_TTL=3600

# Attachments
ATTACHMENT_STORAGE_PATH=./storage/attachments
ATTACHMENT_CACHE_ENABLED=true
ATTACHMENT_MAX_SIZE=25000000

# Uploads
UPLOAD_PATH=./storage/uploads
UPLOAD_MAX_SIZE=50000000
UPLOAD_ALLOWED_EXTENSIONS=csv,txt,zip,html

# Logs
LOG_STORAGE_PATH=./storage/logs

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout

# File Logging
LOG_FILE_ENABLED=true
LOG_FILE_PATH=./storage/logs/app.log
LOG_FILE_MAX_SIZE=100
LOG_FILE_MAX_BACKUPS=10
LOG_FILE_MAX_AGE=30
LOG_FILE_COMPRESS=true

# Campaign Logging
LOG_CAMPAIGN_ENABLED=true
LOG_CAMPAIGN_PATH=./storage/logs/campaigns

# Debug Logging
LOG_DEBUG_ENABLED=true
LOG_DEBUG_PATH=./storage/logs/debug

# Performance Logging
LOG_PERFORMANCE_ENABLED=true
LOG_PERFORMANCE_PATH=./storage/logs/performance

# =============================================================================
# SECURITY & ENCRYPTION
# =============================================================================
# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=168h
JWT_ISSUER=email-campaign-system

# Encryption (AES-256)
ENCRYPTION_KEY=your-32-byte-encryption-key-here-change-me-please!!
ENCRYPTION_ALGORITHM=aes-256-gcm

# API Authentication
API_TOKEN=your-api-token-change-this
API_TOKEN_HEADER=X-API-Token

# Password Hashing
BCRYPT_COST=12

# CORS
CORS_ENABLED=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-API-Token
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=86400

# CSRF Protection
CSRF_ENABLED=true
CSRF_TOKEN_LENGTH=32
CSRF_COOKIE_NAME=csrf_token
CSRF_HEADER_NAME=X-CSRF-Token

# =============================================================================
# EMAIL PROVIDERS - GMAIL
# =============================================================================
GMAIL_ENABLED=true
GMAIL_API_ENDPOINT=https://gmail.googleapis.com/gmail/v1

# OAuth2 Configuration
GMAIL_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GMAIL_OAUTH_CLIENT_SECRET=your-google-client-secret
GMAIL_OAUTH_REDIRECT_URI=http://localhost:8080/auth/callback
GMAIL_OAUTH_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
GMAIL_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
GMAIL_OAUTH_SCOPES=https://www.googleapis.com/auth/gmail.send,https://www.googleapis.com/auth/gmail.compose

# Gmail Limits
GMAIL_DAILY_LIMIT=500
GMAIL_RATE_LIMIT=10
GMAIL_BURST_LIMIT=5

# =============================================================================
# EMAIL PROVIDERS - GOOGLE WORKSPACE
# =============================================================================
WORKSPACE_ENABLED=true
WORKSPACE_SMTP_HOST=smtp.gmail.com
WORKSPACE_SMTP_PORT=587
WORKSPACE_SMTP_ENCRYPTION=starttls
WORKSPACE_DAILY_LIMIT=2000
WORKSPACE_RATE_LIMIT=30

# =============================================================================
# EMAIL PROVIDERS - YAHOO
# =============================================================================
YAHOO_ENABLED=true
YAHOO_SMTP_HOST=smtp.mail.yahoo.com
YAHOO_SMTP_PORT=587
YAHOO_SMTP_ENCRYPTION=starttls
YAHOO_DAILY_LIMIT=500
YAHOO_RATE_LIMIT=10

# =============================================================================
# EMAIL PROVIDERS - OUTLOOK/HOTMAIL
# =============================================================================
OUTLOOK_ENABLED=true
OUTLOOK_SMTP_HOST=smtp-mail.outlook.com
OUTLOOK_SMTP_PORT=587
OUTLOOK_SMTP_ENCRYPTION=starttls
OUTLOOK_DAILY_LIMIT=300
OUTLOOK_RATE_LIMIT=10

HOTMAIL_ENABLED=true
HOTMAIL_SMTP_HOST=smtp.live.com
HOTMAIL_SMTP_PORT=587
HOTMAIL_SMTP_ENCRYPTION=starttls
HOTMAIL_DAILY_LIMIT=300
HOTMAIL_RATE_LIMIT=10

# =============================================================================
# EMAIL PROVIDERS - ICLOUD
# =============================================================================
ICLOUD_ENABLED=true
ICLOUD_SMTP_HOST=smtp.mail.me.com
ICLOUD_SMTP_PORT=587
ICLOUD_SMTP_ENCRYPTION=starttls
ICLOUD_DAILY_LIMIT=200
ICLOUD_RATE_LIMIT=5

# =============================================================================
# EMAIL PROVIDERS - CUSTOM SMTP
# =============================================================================
CUSTOM_SMTP_ENABLED=false
CUSTOM_SMTP_HOST=smtp.example.com
CUSTOM_SMTP_PORT=587
CUSTOM_SMTP_ENCRYPTION=starttls
CUSTOM_SMTP_USERNAME=
CUSTOM_SMTP_PASSWORD=
CUSTOM_SMTP_DAILY_LIMIT=1000
CUSTOM_SMTP_RATE_LIMIT=20

# =============================================================================
# EMAIL SENDING CONFIGURATION
# =============================================================================
# Sender Engine
SENDER_WORKERS=4
SENDER_BATCH_SIZE=10
SENDER_QUEUE_SIZE=1000
SENDER_RATE_LIMIT=5
SENDER_RETRY_ATTEMPTS=3
SENDER_RETRY_DELAY=5s
SENDER_RETRY_MAX_DELAY=60s
SENDER_TIMEOUT=30s

# Connection Pool
SENDER_POOL_SIZE=10
SENDER_POOL_MAX_IDLE=5
SENDER_POOL_IDLE_TIMEOUT=300s
SENDER_POOL_MAX_LIFETIME=3600s

# =============================================================================
# ACCOUNT MANAGEMENT
# =============================================================================
# Account Rotation
ACCOUNT_ROTATION_STRATEGY=health_based
ACCOUNT_ROTATION_LIMIT=100
ACCOUNT_COOLDOWN_PERIOD=300s

# Account Health
ACCOUNT_HEALTH_CHECK_INTERVAL=600s
ACCOUNT_HEALTH_MIN_SCORE=70
ACCOUNT_HEALTH_FAILURE_THRESHOLD=5
ACCOUNT_HEALTH_SUCCESS_THRESHOLD=10

# Account Suspension
ACCOUNT_AUTO_SUSPEND=true
ACCOUNT_SUSPEND_ON_SPAM=true
ACCOUNT_SUSPEND_CONSECUTIVE_FAILURES=5
ACCOUNT_SUSPEND_ERROR_RATE_THRESHOLD=0.3

# Account Limits
ACCOUNT_DAILY_LIMIT_ENABLED=true
ACCOUNT_ROTATION_LIMIT_ENABLED=true

# =============================================================================
# TEMPLATE SYSTEM
# =============================================================================
TEMPLATE_ROTATION_ENABLED=true
TEMPLATE_ROTATION_STRATEGY=round_robin
TEMPLATE_UNLIMITED_ROTATION=true
TEMPLATE_VALIDATION_ENABLED=true
TEMPLATE_SANITIZATION_ENABLED=true

# Spam Detection
TEMPLATE_SPAM_CHECK_ENABLED=true
TEMPLATE_SPAM_THRESHOLD=0.7
TEMPLATE_SPAM_KEYWORDS_FILE=./configs/spam_keywords.txt

# =============================================================================
# PERSONALIZATION ENGINE
# =============================================================================
PERSONALIZATION_ENABLED=true
PERSONALIZATION_CACHE_ENABLED=true

# Variable Configuration
PERSONALIZATION_EXTRACT_NAMES=true
PERSONALIZATION_DATE_FORMAT=2006-01-02
PERSONALIZATION_TIMEZONE=UTC

# Random Generators
PERSONALIZATION_RANDOM_SEED=auto
PERSONALIZATION_INVOICE_PREFIX=INV
PERSONALIZATION_INVOICE_LENGTH=8

# =============================================================================
# ROTATION SYSTEM
# =============================================================================
# Sender Name Rotation
ROTATION_SENDER_NAME_ENABLED=true
ROTATION_SENDER_NAME_STRATEGY=round_robin

# Subject Rotation
ROTATION_SUBJECT_ENABLED=true
ROTATION_SUBJECT_STRATEGY=random

# Custom Field Rotation
ROTATION_CUSTOM_FIELD_ENABLED=true
ROTATION_CUSTOM_FIELD_MAX=20

# Rotation Persistence
ROTATION_PERSIST_STATE=true
ROTATION_SAVE_INTERVAL=60s

# Rotation Statistics
ROTATION_TRACK_STATS=true
ROTATION_STATS_RETENTION=2160h

# =============================================================================
# ATTACHMENT PROCESSING
# =============================================================================
ATTACHMENT_ENABLED=false
ATTACHMENT_CONVERSION_BACKEND=chromedp

# HTML to PDF
ATTACHMENT_PDF_ENABLED=true
ATTACHMENT_PDF_CHROMEDP_PATH=/usr/bin/chromium

# Image Conversion
ATTACHMENT_IMAGE_ENABLED=true
ATTACHMENT_IMAGE_QUALITY=90

# Format Rotation
ATTACHMENT_FORMAT_ROTATION=false
ATTACHMENT_FORMATS=pdf,jpg,png,webp

# Attachment Cache
ATTACHMENT_CACHE_ENABLED=true
ATTACHMENT_CACHE_PATH=./storage/cache/attachments
ATTACHMENT_CACHE_TTL=86400

# =============================================================================
# PROXY SYSTEM
# =============================================================================
PROXY_ENABLED=false
PROXY_ROTATION_ENABLED=false
PROXY_ROTATION_STRATEGY=round_robin

# Proxy Validation
PROXY_HEALTH_CHECK_ENABLED=true
PROXY_HEALTH_CHECK_INTERVAL=600s
PROXY_HEALTH_CHECK_TIMEOUT=10s
PROXY_FAILURE_THRESHOLD=3

# Proxy Types
PROXY_HTTP_ENABLED=true
PROXY_HTTPS_ENABLED=true
PROXY_SOCKS5_ENABLED=true

# =============================================================================
# NOTIFICATION SYSTEM (TELEGRAM)
# =============================================================================
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
TELEGRAM_PARSE_MODE=Markdown

# Notification Events
TELEGRAM_NOTIFY_CAMPAIGN_START=true
TELEGRAM_NOTIFY_CAMPAIGN_COMPLETE=true
TELEGRAM_NOTIFY_CAMPAIGN_FAILED=true
TELEGRAM_NOTIFY_CAMPAIGN_PAUSED=true
TELEGRAM_NOTIFY_ACCOUNT_SUSPENDED=true
TELEGRAM_NOTIFY_ERROR=true

# Notification Queue
TELEGRAM_QUEUE_ENABLED=true
TELEGRAM_QUEUE_SIZE=100
TELEGRAM_RATE_LIMIT=30

# =============================================================================
# WEBSOCKET CONFIGURATION
# =============================================================================
WEBSOCKET_ENABLED=true
WEBSOCKET_PATH=/ws
WEBSOCKET_READ_BUFFER_SIZE=1024
WEBSOCKET_WRITE_BUFFER_SIZE=1024
WEBSOCKET_HANDSHAKE_TIMEOUT=10s
WEBSOCKET_PING_INTERVAL=54s
WEBSOCKET_PONG_WAIT=60s
WEBSOCKET_WRITE_WAIT=10s
WEBSOCKET_MAX_MESSAGE_SIZE=512

# =============================================================================
# CAMPAIGN MANAGEMENT
# =============================================================================
# Campaign Lifecycle
CAMPAIGN_AUTO_START=false
CAMPAIGN_AUTO_CLEANUP=true
CAMPAIGN_CLEANUP_INTERVAL=3600s
CAMPAIGN_CLEANUP_RETENTION=720h

# Campaign State
CAMPAIGN_PERSIST_STATE=true
CAMPAIGN_STATE_SAVE_INTERVAL=60s
CAMPAIGN_CHECKPOINT_INTERVAL=300s

# Campaign Monitoring
CAMPAIGN_PROGRESS_UPDATE_INTERVAL=5s
CAMPAIGN_STATS_UPDATE_INTERVAL=10s

# =============================================================================
# RECIPIENT MANAGEMENT
# =============================================================================
RECIPIENT_VALIDATION_ENABLED=true
RECIPIENT_DNS_CHECK_ENABLED=true
RECIPIENT_DEDUPLICATION_ENABLED=true
RECIPIENT_IMPORT_BATCH_SIZE=1000

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_ALGORITHM=token_bucket
RATE_LIMIT_STORAGE=redis

# Global Rate Limits
RATE_LIMIT_GLOBAL_ENABLED=true
RATE_LIMIT_GLOBAL_REQUESTS=1000
RATE_LIMIT_GLOBAL_WINDOW=60s

# Per-Account Rate Limits
RATE_LIMIT_PER_ACCOUNT=true
RATE_LIMIT_ACCOUNT_REQUESTS=10
RATE_LIMIT_ACCOUNT_WINDOW=60s

# Adaptive Rate Limiting
RATE_LIMIT_ADAPTIVE=true
RATE_LIMIT_ADAPTIVE_MIN_RATE=1
RATE_LIMIT_ADAPTIVE_MAX_RATE=50
RATE_LIMIT_ADAPTIVE_ADJUSTMENT_FACTOR=0.1

# =============================================================================
# DELIVERABILITY
# =============================================================================
# Email Headers
DELIVERABILITY_FBL_ENABLED=true
DELIVERABILITY_FBL_ID=your-feedback-id

DELIVERABILITY_UNSUBSCRIBE_ENABLED=true
DELIVERABILITY_UNSUBSCRIBE_URL=https://yourdomain.com/unsubscribe
DELIVERABILITY_UNSUBSCRIBE_HMAC_SECRET=your-unsubscribe-hmac-secret

# Message Format
DELIVERABILITY_MESSAGE_ID_DOMAIN=yourdomain.com
DELIVERABILITY_MIME_MULTIPART=true
DELIVERABILITY_TEXT_PLAIN_FALLBACK=true

# Reputation Management
DELIVERABILITY_TRACK_REPUTATION=true
DELIVERABILITY_SPAM_SCORE_THRESHOLD=0.7

# =============================================================================
# PERFORMANCE & OPTIMIZATION
# =============================================================================
# Memory Management
MEMORY_LIMIT=2048
MEMORY_GC_PERCENT=100
MEMORY_OPTIMIZE_RECIPIENT_LOADING=true

# Concurrency
CONCURRENCY_MAX_GOROUTINES=1000
CONCURRENCY_WORKER_POOL_SIZE=10

# Batch Processing
BATCH_PROCESSING_ENABLED=true
BATCH_SIZE=100
BATCH_FLUSH_INTERVAL=30s

# =============================================================================
# MONITORING & METRICS
# =============================================================================
METRICS_ENABLED=true
METRICS_PATH=/metrics
METRICS_PORT=9090

# Prometheus
PROMETHEUS_ENABLED=false
PROMETHEUS_PUSH_GATEWAY=http://localhost:9091

# Health Check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_INTERVAL=30s

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_ROTATION=true
FEATURE_ATTACHMENTS=false
FEATURE_PROXIES=false
FEATURE_TELEGRAM=false
FEATURE_WEBSOCKET=true
FEATURE_SPAM_DETECTION=true
FEATURE_A_B_TESTING=false

# =============================================================================
# DEVELOPMENT & DEBUG
# =============================================================================
# Development Mode
DEV_MODE=true
DEV_HOT_RELOAD=false
DEV_MOCK_PROVIDERS=false
DEV_DISABLE_AUTH=false

# Debug Features
DEBUG_SQL_QUERIES=false
DEBUG_HTTP_REQUESTS=false
DEBUG_SHOW_ERRORS=true
DEBUG_PROFILING=false
DEBUG_PPROF_ENABLED=false
DEBUG_PPROF_PORT=6060

# Testing
TEST_MODE=false
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5433/test_email_campaign?sslmode=disable
TEST_REDIS_URL=redis://localhost:6380/0
TEST_MOCK_EMAIL_SENDING=true

# =============================================================================
# EXTERNAL SERVICES (OPTIONAL)
# =============================================================================
# Sentry (Error Tracking)
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0

# AWS (if using S3 for storage)
AWS_ENABLED=false
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# =============================================================================
# TIMEZONE & LOCALIZATION
# =============================================================================
DEFAULT_TIMEZONE=UTC
DEFAULT_LOCALE=en_US
DEFAULT_DATE_FORMAT=2006-01-02
DEFAULT_TIME_FORMAT=15:04:05

# =============================================================================
# MAINTENANCE
# =============================================================================
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE="System under maintenance. Please try again later."
MAINTENANCE_ALLOWED_IPS=127.0.0.1,::1

# =============================================================================
# BACKUP & RECOVERY
# =============================================================================
BACKUP_ENABLED=false
BACKUP_PATH=./backups
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# =============================================================================
# END OF CONFIGURATION
# =============================================================================
